							"raw": "{\n  \"name\": \"Henrique\",\n  \"email\": \"teste@tcc.com\",\n  \"password\": \"senha123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
